# ───────────────────────────────────────────────────────────────────
# KronosStock 환경설정 예시.  복사해서 사용:  cp .env.example .env
# .env 는 .gitignore 처리됨 — 절대 커밋 금지.
# ───────────────────────────────────────────────────────────────────

# ── 한국투자증권 실전(real) — KIS 사용 시 필수 ──
#   python-kis v2.x 는 실전 자격증명을 1차 인증으로 '반드시' 요구한다.
#   시세/차트(OHLCV) 조회는 모의투자 모드에서도 실전 도메인을 사용하므로
#   Phase 1(데이터 수집)에는 아래 실전 키만 채우면 된다.
KIS_HTS_ID=
KIS_APPKEY=
KIS_APPSECRET=
KIS_ACCOUNT=

# ── 한국투자증권 모의투자(virtual) — 모의 '주문'(Phase 2+)에만 필요(선택) ──
#   모의투자는 별도 appkey/appsecret 가 발급된다. 주문을 모의로 보내려면 채운다.
KIS_VIRTUAL_APPKEY=
KIS_VIRTUAL_APPSECRET=
KIS_VIRTUAL_ACCOUNT=
KIS_VIRTUAL_HTS_ID=

# ── KIS 동작 옵션 ──
# (값과 같은 줄에 주석을 두지 않는다 — 파서에 따라 값에 섞일 수 있음)
# KIS_USE_VIRTUAL: 주문을 모의투자로 라우팅(안전 기본값)
KIS_USE_VIRTUAL=true
# KIS_KEEP_TOKEN: OAuth2 토큰 디스크 캐시(24h, 과다발급 방지)
KIS_KEEP_TOKEN=true
# KIS_TOKEN_DIR: 토큰 캐시 디렉터리(기본 .cache → compose 의 kis-cache 볼륨에 매핑)
KIS_TOKEN_DIR=.cache
# KIS_USE_WEBSOCKET: 실시간 웹소켓(불필요하면 false → REST 폴링만)
KIS_USE_WEBSOCKET=false

# ── Redis (KronosKit 과 공유 가능; 키 prefix 로 네임스페이스 분리) ──
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=kronos:stock:

# ── Telegram 개인 알림 ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Kronos-mini 모델 ──
KRONOS_MODEL_REPO=NeoQuasar/Kronos-mini
KRONOS_TOKENIZER_REPO=NeoQuasar/Kronos-Tokenizer-2k
KRONOS_DEVICE=cpu
KRONOS_MAX_CONTEXT=2048
KRONOS_LOOKBACK=400
KRONOS_PRED_LEN=5

# ── 워치리스트(콤마 구분) ──
WATCHLIST=005930,000660,035420,051910,006400

# ── 스케줄(KST, 선택 — 미지정 시 config.py 기본값 사용) ──
SCHEDULE_PREMARKET=08:50
SCHEDULE_OPEN=09:30
SCHEDULE_MIDDAY=12:00
SCHEDULE_CLOSE=15:20

# ── 기타 ──
TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO
